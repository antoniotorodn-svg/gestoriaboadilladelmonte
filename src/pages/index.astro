---
import Layout from '../layouts/Layout.astro';
import { services } from '../data/services';
import { zones } from '../data/zones';
import { blogPosts } from '../data/blogPosts';

const latestPosts = [...blogPosts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).slice(0, 3);
---
<Layout
  title="Gestoría Boadilla del Monte | Asesoría Fiscal, Laboral y Contable"
  description="Gestoría en Boadilla del Monte. Servicios 100% online de asesoría fiscal, laboral y contable para autónomos, pymes y particulares. 30 años de experiencia. ¡Llámanos!"
>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <span class="hero__label">Gestoría en Boadilla del Monte</span>
        <h1>Tu gestoría de confianza en <em>Boadilla del Monte</em></h1>
        <p class="hero__text">
          Somos Salander Soluciones, una gestoría fiscal, laboral y contable especializada en autónomos y pymes.
          Te ayudamos con tus obligaciones fiscales sin complicaciones.
        </p>
        <div class="hero__actions">
          <a href="/contacto/" class="btn btn--secondary btn--lg">Contactar Ahora</a>
          <a href="tel:+34916324013" class="btn btn--outline btn--lg">Llamar: 916 32 40 13</a>
        </div>
        <div class="hero__trust">
          <div class="hero__google">
            <div class="hero__stars">
              <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
            </div>
            <span class="hero__rating">5.0 en Google <span class="hero__reviews-count">(19 reseñas)</span></span>
          </div>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__card">
          <div class="hero__card-top">
            <span class="hero__card-badge">100% Online</span>
          </div>
          <h3>¿Necesitas una gestoría?</h3>
          <p>30 años de experiencia. Gestión 100% online, sencilla y sin complicaciones.</p>
          <a href="tel:+34916324013" class="btn btn--secondary">Llámanos: 916 32 40 13</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST NUMBERS -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-bar__item">
        <strong>+500</strong>
        <span>Clientes satisfechos</span>
      </div>
      <div class="trust-bar__divider"></div>
      <div class="trust-bar__item">
        <strong>+30 años</strong>
        <span>De experiencia</span>
      </div>
      <div class="trust-bar__divider"></div>
      <div class="trust-bar__item">
        <strong>5.0 &#9733;</strong>
        <span>Valoración en Google</span>
      </div>
      <div class="trust-bar__divider"></div>
      <div class="trust-bar__item">
        <strong>100%</strong>
        <span>Servicio Online</span>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section" id="servicios">
    <div class="container">
      <div class="section__header">
        <span class="section__subtitle">Nuestros servicios</span>
        <h2>Servicios de gestoría en Boadilla del Monte</h2>
        <p>Ofrecemos un servicio integral para que puedas centrarte en lo que realmente importa: tu negocio.</p>
      </div>
      <div class="grid grid--3">
        {services.map(service => (
          <a href={`/servicios/${service.slug}/`} class="card">
            <span class="card__icon">{service.icon}</span>
            <h3 class="card__title">{service.name}</h3>
            <p class="card__text">{service.shortDescription}</p>
            <span class="card__link">Más información &#8594;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="section section--alt" id="por-que">
    <div class="container">
      <div class="section__header">
        <span class="section__subtitle">¿Por qué elegirnos?</span>
        <h2>Una gestoría cercana, profesional y eficiente</h2>
      </div>
      <div class="grid grid--4 why-grid">
        <div class="why-item">
          <div class="why-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
          <h3>Trato personalizado</h3>
          <p>Cada cliente es único. Analizamos tu situación y te ofrecemos soluciones adaptadas.</p>
        </div>
        <div class="why-item">
          <div class="why-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>Experiencia contrastada</h3>
          <p>Más de 30 años asesorando a autónomos y empresas en Boadilla del Monte.</p>
        </div>
        <div class="why-item">
          <div class="why-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          </div>
          <h3>Online o presencial</h3>
          <p>Trabaja con nosotros como prefieras, con la misma calidad de servicio.</p>
        </div>
        <div class="why-item">
          <div class="why-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h3>100% Online</h3>
          <p>Gestión totalmente online, sencilla y sin complicaciones. Estés donde estés.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GOOGLE REVIEWS -->
  <section class="section" id="resenas">
    <div class="container">
      <div class="section__header">
        <span class="section__subtitle">Reseñas de Google</span>
        <h2>Lo que dicen nuestros clientes</h2>
        <div class="reviews-summary">
          <div class="reviews-summary__stars">
            <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
          </div>
          <span class="reviews-summary__text">5.0 de media en Google (19 reseñas)</span>
        </div>
      </div>
      <div class="grid grid--3 reviews-grid">
        <div class="review-card">
          <div class="review-card__header">
            <div class="review-card__avatar">M</div>
            <div>
              <strong class="review-card__name">María G.</strong>
              <span class="review-card__badge">Local Guide</span>
            </div>
          </div>
          <div class="review-card__stars">
            <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
          </div>
          <p class="review-card__text">"Excelente servicio. Muy profesionales y cercanos. Me ayudaron con toda la gestión fiscal de mi empresa sin complicaciones. Totalmente recomendables."</p>
        </div>
        <div class="review-card">
          <div class="review-card__header">
            <div class="review-card__avatar">J</div>
            <div>
              <strong class="review-card__name">Juan Carlos R.</strong>
              <span class="review-card__badge">Local Guide</span>
            </div>
          </div>
          <div class="review-card__stars">
            <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
          </div>
          <p class="review-card__text">"Llevo años con ellos y estoy encantado. Me resolvieron un problema con Hacienda de forma rápida y eficaz. Trato muy personalizado."</p>
        </div>
        <div class="review-card">
          <div class="review-card__header">
            <div class="review-card__avatar">A</div>
            <div>
              <strong class="review-card__name">Ana P.</strong>
            </div>
          </div>
          <div class="review-card__stars">
            <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
          </div>
          <p class="review-card__text">"Me dieron de alta como autónoma y se encargan de todas mis declaraciones. Muy atentos y siempre disponibles. La mejor gestoría de la zona."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt" id="faq">
    <div class="container">
      <div class="section__header">
        <span class="section__subtitle">Preguntas frecuentes</span>
        <h2>Preguntas frecuentes sobre asesoría y gestiones varias</h2>
        <p>¿Tienes alguna duda? Puede que esta sección despeje alguna de ellas:</p>
      </div>
      <div class="content">
        <details class="faq-item">
          <summary>¿Por qué debería contratar vuestra gestoría en lugar de hacer los trámites por mi cuenta?</summary>
          <p>Hacerlo por tu cuenta puede llevarte mucho tiempo y, si no dominas la normativa, podrías cometer errores que terminen costándote dinero en sanciones o impuestos mal gestionados. Nosotros nos encargamos de todo para que tú puedas centrarte en hacer crecer tu negocio con la tranquilidad de que todo está en orden.</p>
        </details>
        <details class="faq-item">
          <summary>¿Qué impuestos gestionáis para autónomos y empresas?</summary>
          <p>Presentamos declaraciones de IVA, IRPF, Impuesto de Sociedades y otros tributos específicos según tu actividad. Además, te recordamos los plazos y te ayudamos a optimizar el pago de impuestos dentro del marco legal. Si tienes dudas sobre un caso concreto, estamos aquí para asesorarte.</p>
        </details>
        <details class="faq-item">
          <summary>¿Podéis ayudarme con las nóminas y contratos de mis empleados?</summary>
          <p>Sí, nos ocupamos de la gestión de nóminas, seguros sociales y la elaboración de contratos adaptados a la normativa vigente. Así evitas errores y posibles sanciones, asegurándote de que todo está en regla.</p>
        </details>
        <details class="faq-item">
          <summary>¿Qué documentación necesito para gestionar mis impuestos o trámites laborales con vosotros?</summary>
          <p>Dependerá del servicio que necesites, pero en general te pediremos facturas, recibos, contratos, datos de la Seguridad Social y cualquier otra información relevante. No te preocupes, nosotros te guiaremos en cada paso para que sea lo más sencillo posible.</p>
        </details>
        <details class="faq-item">
          <summary>Si recibo una notificación o inspección de Hacienda o la Seguridad Social, ¿podéis ayudarme?</summary>
          <p>Por supuesto. Analizaremos la situación, te explicaremos qué hacer y nos ocuparemos de la gestión para proteger tus intereses. Si necesitas ayuda urgente, no dudes en llamarnos.</p>
        </details>
        <details class="faq-item">
          <summary>¿Cada cuánto tiempo hay que presentar los impuestos y trámites laborales?</summary>
          <p>Depende del tipo de impuesto o trámite. Por ejemplo, el IVA suele ser trimestral, mientras que las nóminas y cotizaciones se presentan cada mes. No te preocupes por los plazos, nosotros nos encargamos de que todo se presente a tiempo.</p>
        </details>
        <details class="faq-item">
          <summary>¿Podéis gestionar el alta, baja o modificaciones de autónomos o empresas?</summary>
          <p>Sí, nos ocupamos de todo lo necesario para que puedas darte de alta, hacer cambios en tu actividad o gestionar una baja sin complicaciones. Lo hacemos de forma ágil para que tú no pierdas tiempo en papeleos.</p>
        </details>
        <details class="faq-item">
          <summary>¿Trabajáis solo en Boadilla del Monte o también en otras zonas?</summary>
          <p>Ofrecemos nuestros servicios 100% online, así que podemos ayudarte estés donde estés. Aunque estamos ubicados en Boadilla del Monte, trabajamos con clientes de toda España. Es muy sencillo: nos envías la documentación por email y nosotros nos encargamos de todo.</p>
        </details>
        <details class="faq-item">
          <summary>¿Qué pasa si me retraso en un trámite fiscal o laboral? ¿Podéis solucionarlo?</summary>
          <p>Sí, analizamos tu caso y vemos la mejor forma de regularizar la situación. Si hay sanciones o intereses de demora, te ayudamos a gestionarlos y te damos pautas para que no vuelva a ocurrir. Cuanto antes nos llames, mejor podremos solucionarlo.</p>
        </details>
        <details class="faq-item">
          <summary>¿Cómo empiezo a trabajar con vosotros?</summary>
          <p>Es muy fácil. Contáctanos por teléfono, email o a través de nuestro formulario y te explicaremos cómo trabajamos. A partir de ahí, nos encargamos de todo para que empieces a beneficiarte de nuestros servicios sin complicaciones.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="section" id="blog">
    <div class="container">
      <div class="section__header">
        <span class="section__subtitle">Nuestro blog</span>
        <h2>Artículos y consejos de tu gestoría</h2>
        <p>Publicamos guías y artículos sobre fiscalidad, laboral y gestión empresarial para ayudarte a tomar mejores decisiones.</p>
      </div>
      <div class="grid grid--3">
        {latestPosts.map(post => (
          <a href={`/blog/${post.slug}/`} class="card home-blog-card">
            <span class="home-blog-card__category">{post.category}</span>
            <h3 class="card__title">{post.title}</h3>
            <p class="card__text">{post.excerpt}</p>
            <span class="card__link">Leer artículo &#8594;</span>
          </a>
        ))}
      </div>
      <div class="home-blog-cta">
        <a href="/blog/" class="btn btn--outline">Ver todos los artículos</a>
      </div>
    </div>
  </section>

  <!-- ZONES -->
  <section class="section" id="zonas">
    <div class="container">
      <div class="section__header">
        <span class="section__subtitle">Cobertura local</span>
        <h2>Gestoría en todas las zonas de Boadilla del Monte</h2>
        <p>Prestamos servicios de gestoría en todas las urbanizaciones y barrios de Boadilla del Monte.</p>
      </div>
      <div class="zone-links">
        {zones.map(zone => (
          <a href={`/zonas/${zone.slug}/`} class="zone-link">
            Gestoría en {zone.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-section__inner">
      <span class="section__subtitle" style="color: var(--color-secondary-light);">Contacto</span>
      <h2>¿Necesitas una gestoría en Boadilla del Monte?</h2>
      <p>Contacta con nosotros y cuéntanos tu situación. 30 años de experiencia nos avalan.</p>
      <div class="cta-section__actions">
        <a href="/contacto/" class="btn btn--secondary btn--lg">Contactar Ahora</a>
        <a href="tel:+34916324013" class="btn btn--outline btn--lg" style="border-color: rgba(255,255,255,0.4); color: white;">Llamar: 916 32 40 13</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero {
    background-color: var(--color-bg);
    padding: calc(var(--header-height) + var(--space-4xl)) 0 var(--space-4xl);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 45%;
    height: 100%;
    background: linear-gradient(135deg, transparent 0%, rgba(26, 60, 52, 0.03) 100%);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-3xl);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero__label {
    display: inline-block;
    background-color: rgba(26, 60, 52, 0.08);
    color: var(--color-primary);
    padding: var(--space-xs) var(--space-lg);
    border-radius: var(--radius-full);
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: var(--space-lg);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .hero h1 {
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    color: var(--color-primary-dark);
    margin-bottom: var(--space-lg);
    line-height: 1.15;
  }

  .hero h1 em {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero__text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text-light);
    margin-bottom: var(--space-2xl);
    max-width: 520px;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-2xl);
  }

  .hero__trust {
    display: flex;
    align-items: center;
  }

  .hero__google {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero__stars {
    display: flex;
    gap: 2px;
  }

  .hero__stars span {
    color: #f4b400;
    font-size: 1.1rem;
  }

  .hero__rating {
    font-size: 0.9rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .hero__reviews-count {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .hero__card {
    background-color: var(--color-white);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    box-shadow: var(--shadow-lg);
    text-align: center;
    border: 1px solid var(--color-border);
  }

  .hero__card-top {
    margin-bottom: var(--space-lg);
  }

  .hero__card-badge {
    background-color: var(--color-secondary);
    color: var(--color-white);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .hero__card h3 {
    color: var(--color-primary-dark);
    margin-bottom: var(--space-sm);
    font-size: 1.3rem;
  }

  .hero__card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    margin-bottom: var(--space-xl);
  }

  .hero__card .btn {
    width: 100%;
    justify-content: center;
  }

  /* TRUST BAR */
  .trust-bar {
    background-color: var(--color-primary-dark);
    padding: var(--space-2xl) 0;
  }

  .trust-bar__inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-3xl);
    flex-wrap: wrap;
  }

  .trust-bar__item {
    text-align: center;
    color: var(--color-white);
  }

  .trust-bar__item strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .trust-bar__item span {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .trust-bar__divider {
    width: 1px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.15);
  }

  /* WHY US */
  .why-item {
    text-align: center;
    padding: var(--space-xl);
  }

  .why-item__icon {
    width: 60px;
    height: 60px;
    margin: 0 auto var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg);
    border-radius: 50%;
    color: var(--color-primary);
  }

  .why-item h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
  }

  .why-item p {
    font-size: 0.92rem;
  }

  /* REVIEWS */
  .reviews-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .reviews-summary__stars {
    display: flex;
    gap: 2px;
  }

  .reviews-summary__stars span {
    color: #f4b400;
    font-size: 1.2rem;
  }

  .reviews-summary__text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .review-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .review-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .review-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .review-card__name {
    display: block;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .review-card__badge {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    margin-top: 2px;
  }

  .review-card__stars {
    display: flex;
    gap: 2px;
    margin-bottom: var(--space-md);
  }

  .review-card__stars span {
    color: #f4b400;
    font-size: 0.95rem;
  }

  .review-card__text {
    font-size: 0.92rem;
    color: var(--color-text-light);
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 0;
  }

  /* CTA */
  .cta-section {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    padding: var(--space-5xl) 0;
    text-align: center;
  }

  .cta-section h2 {
    color: var(--color-white);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    margin-bottom: var(--space-md);
  }

  .cta-section p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
    margin-bottom: var(--space-2xl);
  }

  .cta-section__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* BLOG */
  .home-blog-card__category {
    display: inline-block;
    background-color: rgba(26, 60, 52, 0.08);
    color: var(--color-primary);
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
