---
import Layout from '../layouts/Layout.astro';

const siteUrl = 'https://gestoriaboadilladelmonte.com';
---
<Layout
  title="Contacto | Gestoría en Boadilla del Monte - Salander Soluciones"
  description="Contacta con tu gestoría en Boadilla del Monte. Llámanos al 916 32 40 13 o envíanos un mensaje. Asesoría fiscal, laboral y contable. 30 años de experiencia. Servicio 100% online."
  breadcrumbs={[
    { name: "Inicio", url: siteUrl + "/" },
    { name: "Contacto", url: siteUrl + "/contacto/" }
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contacto - Gestoría Boadilla del Monte",
    "description": "Página de contacto de Gestoría Boadilla del Monte - Salander Soluciones. Asesoría fiscal, laboral y contable en Boadilla del Monte, Madrid.",
    "url": siteUrl + "/contacto/",
    "mainEntity": {
      "@type": "AccountingService",
      "name": "Gestoría Boadilla del Monte - Salander Soluciones",
      "url": siteUrl,
      "telephone": "+34 916 324 013",
      "email": "clientes@salandersoluciones.es",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Calle Geranio, 11",
        "postalCode": "28660",
        "addressLocality": "Boadilla del Monte",
        "addressRegion": "Madrid",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "40.4058",
        "longitude": "-3.8769"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "10:00",
        "closes": "20:00"
      },
      "areaServed": [
        { "@type": "City", "name": "Boadilla del Monte", "sameAs": "https://es.wikipedia.org/wiki/Boadilla_del_Monte" },
        { "@type": "AdministrativeArea", "name": "Madrid" }
      ],
      "priceRange": "€€",
      "image": siteUrl + "/favicon.svg",
      "hasMap": "https://maps.google.com/?q=Calle+Geranio+11+28660+Boadilla+del+Monte+Madrid"
    }
  })} />

  <section class="page-hero">
    <div class="container">
      <div class="breadcrumbs">
        <a href="/">Inicio</a> <span>›</span> Contacto
      </div>
      <h1>Contacta con tu gestoría en Boadilla del Monte</h1>
      <p>Cuéntanos cómo podemos ayudarte. Asesoría fiscal, laboral y contable con atención personalizada y servicio 100% online.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-layout">
      <div class="contact-layout__form">
        <h2>Escríbenos desde Boadilla del Monte o cualquier lugar</h2>
        <p>Rellena el formulario y nos pondremos en contacto contigo en menos de 24 horas. Asesoría fiscal, laboral y contable personalizada.</p>

        <form class="contact-form" id="contact-form">
          <input type="hidden" name="access_key" value="485009d6-efb2-4d6d-b74b-573861e2ecef" />
          <input type="hidden" name="subject" value="Nuevo mensaje desde gestoriaboadilladelmonte.com" />
          <input type="hidden" name="from_name" value="Gestoría Boadilla - Web" />
          <input type="checkbox" name="botcheck" style="display: none;" />

          <div class="form-row">
            <div class="form-group">
              <label for="nombre">Nombre *</label>
              <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
            </div>
            <div class="form-group">
              <label for="apellidos">Apellidos *</label>
              <input type="text" id="apellidos" name="apellidos" required placeholder="Tus apellidos" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required placeholder="tu@email.com" />
            </div>
            <div class="form-group">
              <label for="telefono">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" placeholder="916 32 40 13" />
            </div>
          </div>

          <div class="form-group">
            <label for="servicio">¿En qué podemos ayudarte?</label>
            <select id="servicio" name="servicio">
              <option value="">Selecciona un servicio</option>
              <option value="gestoria-fiscal">Gestoría Fiscal</option>
              <option value="gestoria-laboral">Gestoría Laboral</option>
              <option value="gestoria-contable">Gestoría Contable</option>
              <option value="asesoria-legal">Asesoría Legal</option>
              <option value="alta-autonomos">Alta de Autónomos</option>
              <option value="constitucion-empresas">Constitución de Empresas</option>
              <option value="certificado-digital">Certificado Digital</option>
              <option value="declaracion-renta">Declaración de la Renta</option>
              <option value="impuesto-sociedades">Impuesto de Sociedades</option>
              <option value="tramites-administrativos">Trámites Administrativos</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div class="form-group">
            <label for="mensaje">Mensaje *</label>
            <textarea id="mensaje" name="mensaje" required placeholder="Cuéntanos tu situación y cómo podemos ayudarte..."></textarea>
          </div>

          <div class="form-group form-group--checkbox">
            <label>
              <input type="checkbox" name="privacidad" required />
              He leído y acepto la <a href="/proteccion-de-datos/">Protección de Datos</a> *
            </label>
          </div>

          <button type="submit" class="btn btn--primary btn--lg" id="submit-btn">Enviar mensaje</button>

          <div id="form-success" class="form-message form-message--success" style="display:none;">
            Mensaje enviado correctamente. Nos pondremos en contacto contigo en menos de 24 horas.
          </div>
          <div id="form-error" class="form-message form-message--error" style="display:none;">
            Ha ocurrido un error al enviar el mensaje. Por favor, inténtalo de nuevo o llámanos al 916 32 40 13.
          </div>
        </form>
      </div>

      <aside class="contact-layout__info">
        <div class="contact-card">
          <h3>Datos de contacto</h3>

          <div class="contact-item">
            <div class="contact-item__icon">📞</div>
            <div>
              <strong>Teléfono</strong>
              <a href="tel:+34916324013">916 32 40 13</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item__icon">📧</div>
            <div>
              <strong>Email</strong>
              <a href="mailto:clientes@salandersoluciones.es">clientes@salandersoluciones.es</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item__icon">🕐</div>
            <div>
              <strong>Horario de atención</strong>
              <span>Lunes a Viernes: 10:00 - 20:00</span>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-item__icon">📍</div>
            <div>
              <strong>Ubicación</strong>
              <span>Calle Geranio, 11. 28660 Boadilla del Monte (Madrid)</span>
            </div>
          </div>
        </div>

        <div class="contact-card contact-card--highlight">
          <h3>100% Online y sencillo</h3>
          <p>Trabajamos de forma totalmente online. Con más de 30 años de experiencia, te ofrecemos un servicio profesional y cercano estés donde estés.</p>
        </div>

        <div class="contact-card">
          <h3>¿Prefieres llamar?</h3>
          <p>Si prefieres hablar directamente con nosotros, llámanos al:</p>
          <a href="tel:+34916324013" class="btn btn--secondary" style="width:100%; justify-content:center;">916 32 40 13</a>
        </div>

        <div class="contact-card">
          <h3>Nuestra ubicación en Boadilla del Monte</h3>
          <div class="contact-map">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3038.5!2d-3.8769!3d40.4058!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sCalle+Geranio+11+Boadilla+del+Monte!5e0!3m2!1ses!2ses!4v1"
              width="100%"
              height="200"
              style="border:0; border-radius: 8px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de Gestoría Boadilla del Monte en Calle Geranio 11"
            ></iframe>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Gestoría en Boadilla del Monte: servicio cercano y profesional</h2>
        <p>En Salander Soluciones llevamos más de 30 años ofreciendo servicios de gestoría fiscal, laboral y contable en Boadilla del Monte y toda la zona oeste de Madrid. Atendemos a autónomos, pymes y particulares de todas las urbanizaciones: Casco Histórico, Las Lomas, Montepríncipe, Viñas Viejas, El Pastel y muchas más.</p>
      </div>
      <div class="grid grid--3">
        <div class="local-seo-item">
          <h3>Gestoría fiscal en Boadilla del Monte</h3>
          <p>Declaración de la Renta, IVA, Impuesto de Sociedades y todas tus obligaciones tributarias gestionadas por profesionales con experiencia en Boadilla del Monte.</p>
        </div>
        <div class="local-seo-item">
          <h3>Gestoría laboral en Boadilla del Monte</h3>
          <p>Nóminas, contratos, altas y bajas en la Seguridad Social. Gestión laboral completa para empresas y autónomos de Boadilla del Monte y alrededores.</p>
        </div>
        <div class="local-seo-item">
          <h3>Asesoría contable en Boadilla del Monte</h3>
          <p>Contabilidad, cuentas anuales y libros contables. Asesoramiento contable adaptado a tu negocio en Boadilla del Monte, Madrid.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .contact-layout__form h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-sm);
  }

  .contact-layout__form > p {
    color: var(--color-text-light);
    margin-bottom: var(--space-2xl);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .form-group--checkbox label {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.9rem;
    font-weight: 400;
    cursor: pointer;
  }

  .form-group--checkbox input[type="checkbox"] {
    width: auto;
  }

  .form-group--checkbox a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .contact-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .contact-card--highlight {
    background-color: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
    color: var(--color-white);
  }

  .contact-card--highlight h3 {
    color: var(--color-white);
  }

  .contact-card--highlight p {
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 0;
  }

  .contact-card h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-lg);
    color: var(--color-primary-dark);
  }

  .contact-card p {
    font-size: 0.9rem;
    margin-bottom: var(--space-lg);
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .contact-item:last-child {
    border-bottom: none;
  }

  .contact-item__icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-item strong {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 2px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .contact-item a,
  .contact-item span {
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .contact-item a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 992px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 576px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-message {
    margin-top: var(--space-lg);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .form-message--success {
    background-color: #e8f5e9;
    color: #2e7d32;
    border: 1px solid #a5d6a7;
  }

  .form-message--error {
    background-color: #fce4ec;
    color: #c62828;
    border: 1px solid #ef9a9a;
  }

  .btn--loading {
    opacity: 0.7;
    pointer-events: none;
  }

  .contact-map {
    margin-top: var(--space-md);
  }

  .contact-map iframe {
    display: block;
    width: 100%;
  }

  .local-seo-item {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .local-seo-item h3 {
    font-size: 1.05rem;
    color: var(--color-primary-dark);
    margin-bottom: var(--space-sm);
  }

  .local-seo-item p {
    font-size: 0.92rem;
    color: var(--color-text-light);
    margin-bottom: 0;
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Enviando...';
    submitBtn.classList.add('btn--loading');
    successMsg.style.display = 'none';
    errorMsg.style.display = 'none';

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await response.json();

      if (data.success) {
        successMsg.style.display = 'block';
        form.reset();
      } else {
        errorMsg.style.display = 'block';
      }
    } catch {
      errorMsg.style.display = 'block';
    } finally {
      submitBtn.textContent = 'Enviar mensaje';
      submitBtn.classList.remove('btn--loading');
    }
  });
</script>
